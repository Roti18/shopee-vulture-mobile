# ═══════════════════════════════════════════════════════════
# Shopee ADB Automation Bot — Environment Variables
# ═══════════════════════════════════════════════════════════
#
# SETUP:
#   cp data/.env.example data/.env
#   nano data/.env   (isi semua nilai yang diperlukan)
#
# JANGAN commit file data/.env ke git!
# ═══════════════════════════════════════════════════════════

# ── Telegram Bot ──────────────────────────────────────────
# Buat bot via @BotFather, dapatkan token
TELEGRAM_TOKEN=your_bot_token_here

# Chat ID untuk menerima notifikasi
# Gunakan @userinfobot atau kirim pesan ke bot lalu cek API
TELEGRAM_CHAT_ID=your_chat_id_here

# ── ADB Device ────────────────────────────────────────────
# Pilih salah satu: USB (serial) atau WiFi (host:port)

# USB: dapatkan serial via "adb devices"
ADB_DEVICE_SERIAL=

# WiFi: format IP:PORT, contoh: 192.168.1.100:5555
# Kosongkan jika menggunakan USB
ADB_WIFI_HOST=

# ═══════════════════════════════════════════════════════════
# Semua konfigurasi runtime lainnya (interval, cooldown,
# blackout, product URL, variant, dll) dapat diatur via
# Telegram command setelah bot berjalan.
#
# Atau set awal via data/config.json sebelum pertama kali
# menjalankan bot.
# ═══════════════════════════════════════════════════════════
